{
  "name": "hacker-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "bun run --filter '@hacker-agent/mcp-server' dev",
    "dev:agent": "bun run --filter '@hacker-agent/agent' dev",
    "dev:sdk": "bun run --filter '@hacker-agent/frontend-sdk' dev",
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:agent\" \"bun run dev:sdk\"",
    "build": "bun run --filter '*' build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "workspaces": [
    "packages/*"
  ]
}
