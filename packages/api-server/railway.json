{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install && cd packages/shared && bun run build && cd ../api-server && bun run build",
    "watchPatterns": [
      "packages/api-server/**",
      "packages/shared/**"
    ]
  },
  "deploy": {
    "startCommand": "cd packages/api-server && bun run start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
