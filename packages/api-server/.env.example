# LLM Provider Configuration
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://llm.internal.company.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL=default
# Optional: lighter model for simple tasks (not yet used; reserved for future task-level routing)
LLM_FAST_MODEL=
LLM_MAX_TOKENS=

# ── Thinking / Reasoning Configuration ──────────────────────────────────────
# Parameters are auto-injected based on model family detected from the model name
# at runtime. Each request's model name is matched dynamically, so switching models
# from the frontend works correctly without restarting the server.
#
# Claude models — thinking.budget_tokens (default: 10240, min: 1024)
#   Set to "0" or "disabled" to turn off.
LLM_THINKING_BUDGET=10240
#
# OpenAI models (gpt-5.1+, o1, o3, o4) — reasoning_effort (default: "medium")
#   Allowed: "low", "medium", "high", "none". Set to "disabled" to skip.
LLM_REASONING_EFFORT=medium
#
# GLM models — extra_body.chat_template_kwargs.enable_thinking (default: true)
#   Set to "false" to disable.
LLM_GLM_THINKING=true

# ── Subagent Configuration ──────────────────────────────────────────────────
# Master kill switch for the subagent feature (default: true)
SUBAGENT_ENABLED=true
# Model for subagent tasks (defaults to LLM_MODEL / the main model if not set)
SUBAGENT_MODEL=
# Maximum execution time per subagent invocation in milliseconds (default: 120000)
SUBAGENT_TIMEOUT_MS=300000
# Maximum number of LLM steps per subagent invocation (default: 30)
SUBAGENT_MAX_STEPS=30
# Maximum number of concurrent subagent invocations per chat request (default: 5)
SUBAGENT_MAX_PARALLEL=5

# Server
PORT=4000

# Instance identifier for log file names (useful for multi-instance deployments)
LOG_PREFIX=ocean-mcp

# ── Zip Skill Cache Configuration ───────────────────────────────────────────
# Maximum total disk size (MB) for cached zip skill extractions.
# Oldest entries are evicted (FIFO) when this limit is exceeded.
OCEAN_SKILL_CACHE_MAX_MB=100
# Maximum allowed size (MB) for a single downloaded .zip skill file.
# Downloads exceeding this limit are rejected.
OCEAN_SKILL_ZIP_MAX_MB=50

